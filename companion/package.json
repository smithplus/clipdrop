{
  "name": "clipdrop-companion",
  "version": "0.4.0",
  "private": true,
  "description": "ClipDrop menu bar app for Adobe Premiere Pro.",
  "main": "src/main.js",
  "scripts": {
    "prepare:binaries": "node scripts/prepare-binaries.js",
    "start": "electron .",
    "build:mac": "npm run prepare:binaries && electron-builder --mac dmg --arm64"
  },
  "devDependencies": {
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "@ffprobe-installer/ffprobe": "2.1.2",
    "ffmpeg-static": "5.3.0"
  },
  "build": {
    "appId": "com.clipdrop.companion",
    "productName": "ClipDrop",
    "asar": true,
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../helper",
        "to": "helper",
        "filter": [
          "src/**/*"
        ]
      },
      {
        "from": "../plugin",
        "to": "plugin",
        "filter": [
          "**/*",
          "!test/**/*"
        ]
      },
      {
        "from": "../package.json",
        "to": "package.json"
      },
      {
        "from": "../dist/ClipDrop-0.4.0.ccx",
        "to": "installer/ClipDrop.ccx"
      },
      {
        "from": "vendor/bin",
        "to": "bin"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "title": "ClipDrop ${version}",
      "artifactName": "ClipDrop-${version}-macOS-arm64.${ext}"
    }
  }
}
