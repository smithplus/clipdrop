{
  "compilerOptions": {
    "skipLibCheck": true,
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": [
      "@adobe/cc-ext-uxp-types",
      "@types/node",
      "@adobe/premierepro"
    ],
    "esModuleInterop": true
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "scripts", "dist", "assets"]
}
