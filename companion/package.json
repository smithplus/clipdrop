{
  "name": "clipdrop-companion",
  "version": "0.4.3",
  "private": true,
  "description": "ClipDrop menu bar app for Adobe Premiere Pro.",
  "main": "src/main.js",
  "scripts": {
    "prepare:binaries": "node scripts/prepare-binaries.js",
    "start": "electron .",
    "build:mac": "npm run prepare:binaries && electron-builder --mac --arm64",
    "build:mac:x64": "CLIPDROP_TARGET_ARCH=x64 npm run prepare:binaries && electron-builder --mac --x64",
    "build:win": "npm run prepare:binaries && electron-builder --win --x64"
  },
  "devDependencies": {
    "electron": "43.2.0",
    "electron-builder": "26.15.3",
    "@electron/notarize": "2.5.0",
    "@ffprobe-installer/ffprobe": "2.1.2",
    "ffmpeg-static": "5.3.0"
  },
  "build": {
    "appId": "com.clipdrop.companion",
    "productName": "ClipDrop",
    "asar": true,
    "afterSign": "scripts/notarize.js",
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../helper",
        "to": "helper",
        "filter": [
          "src/**/*"
        ]
      },
      {
        "from": "../plugin",
        "to": "plugin",
        "filter": [
          "**/*",
          "!test/**/*"
        ]
      },
      {
        "from": "../package.json",
        "to": "package.json"
      },
      {
        "from": "../dist/ClipDrop-0.4.3.ccx",
        "to": "installer/ClipDrop.ccx"
      },
      {
        "from": "vendor/bin",
        "to": "bin"
      }
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "notarize": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "LSUIElement": true
      }
    },
    "dmg": {
      "title": "ClipDrop ${version}",
      "artifactName": "ClipDrop-${version}-macOS-${arch}.${ext}"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "ClipDrop-${version}-Windows-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "runAfterFinish": true
    }
  }
}
